# Personal Finance Manager — Root .gitignore

# ── Node ──────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Build outputs ─────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Environment variables (never commit secrets)
.env
.env.local
.env.development
.env.production
.env.test

# ── Logs ──────────────────────────────────────
*.log
logs/
build.log
build_errors*.log
build_full.log

# ── Editor/IDE ────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── OS ────────────────────────────────────────
.DS_Store
desktop.ini

# ── Test coverage ─────────────────────────────
coverage/
.nyc_output/
